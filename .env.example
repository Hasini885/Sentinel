# Copy this file to .env and adjust as needed. .env is gitignored — never commit real secrets.

# --- Postgres (consumed by docker-compose) ---
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
POSTGRES_PORT=5432

# --- Redis (consumed by docker-compose) ---
REDIS_PORT=6379

# --- Backend (consumed by the FastAPI app + Alembic) ---
# Host/port here must match the docker-compose values above.
DATABASE_URL=postgresql+psycopg2://sentinel:sentinel@localhost:5432/sentinel
REDIS_URL=redis://localhost:6379/0

# --- Risk scorer (Google Gemini, free tier) ---
# Get a free key at https://aistudio.google.com/apikey (no card required).
GEMINI_API_KEY=
RISK_MODEL=gemini-2.0-flash

# Optional: Anthropic is no longer the default scorer, but set this and switch
# RISK_MODEL to a claude-* model to use it instead.
ANTHROPIC_API_KEY=

# --- PostHog outcome analytics (optional) ---
# Project API key (starts with phc_) from PostHog -> Settings -> Project.
# Leave the key empty to disable analytics emission.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
