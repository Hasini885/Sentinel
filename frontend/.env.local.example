# Copy to .env.local and fill in. .env.local is gitignored — never commit it.

# --- Backend API ---
# NEXT_PUBLIC_* is read in the browser, so it must not hold anything secret.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Auth (server-side only — no NEXT_PUBLIC_ prefix, never reaches the client) ---

# Signs the session cookie. Required. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# The seed demo account. Login checks these; /signup adds further accounts to
# the server's memory, which are cleared when the process restarts.
DEMO_USER_EMAIL=demo@sentinel.local
DEMO_USER_NAME=Demo Operator

# bcrypt hash of the demo password — never the password itself. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
#
# IMPORTANT: escape every $ with a backslash. Next expands $NAME in .env files,
# so a bcrypt hash pasted raw ($2b$10$...) is read as three variable references
# and silently arrives truncated — login then fails with no useful error.
# Quotes do NOT help; only backslashes do. So this:
#     $2b$10$abcdef...
# must be written as:
#     \$2b\$10\$abcdef...
DEMO_USER_PASSWORD_HASH=
