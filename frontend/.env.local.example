# Copy to .env.local and fill in. .env.local is gitignored — never commit it.

# --- Backend API ---
# NEXT_PUBLIC_* is read in the browser, so it must not hold anything secret.
# Used only for the WebSocket, which the browser opens directly; REST calls go
# through this app's own /api/sentinel proxy instead.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Where the server-side proxy forwards to. Defaults to NEXT_PUBLIC_API_BASE_URL.
# SENTINEL_API_URL=http://localhost:8000

# Shared secret the proxy attaches when calling FastAPI. MUST match
# SENTINEL_API_KEY in the project-root .env, or every request returns 401.
# No NEXT_PUBLIC_ prefix — this must never reach the browser. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SENTINEL_API_KEY=

# --- Auth (server-side only — no NEXT_PUBLIC_ prefix, never reaches the client) ---

# Signs the session cookie. Required. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Accounts now live in the backend's Postgres `users` table (see the 0006_users
# migration), not in .env. Sign up at /signup to create one; the demo login
# demo@sentinel.local / sentinel-demo is seeded by that migration.
